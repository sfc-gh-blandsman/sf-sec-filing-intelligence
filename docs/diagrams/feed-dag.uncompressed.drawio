<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram id="feed-dag" name="Feed Ingestion DAG">
    <mxGraphModel dx="1400" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Feed Ingestion DAG — Multi-Year Loop" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=14;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="400" height="30" as="geometry" />
        </mxCell>

        <!-- ROOT -->
        <mxCell id="root" value="T_FEED_INGEST_ROOT&#xa;(clears partial logs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="70" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- Month tasks -->
        <mxCell id="jan" value="JAN" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="180" width="60" height="35" as="geometry" />
        </mxCell>
        <mxCell id="feb" value="FEB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="130" y="180" width="60" height="35" as="geometry" />
        </mxCell>
        <mxCell id="mar" value="MAR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="210" y="180" width="60" height="35" as="geometry" />
        </mxCell>
        <mxCell id="apr" value="APR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="290" y="180" width="60" height="35" as="geometry" />
        </mxCell>
        <mxCell id="may" value="MAY" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="370" y="180" width="60" height="35" as="geometry" />
        </mxCell>
        <mxCell id="jun" value="JUN" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="450" y="180" width="60" height="35" as="geometry" />
        </mxCell>
        <mxCell id="jul" value="JUL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="530" y="180" width="60" height="35" as="geometry" />
        </mxCell>
        <mxCell id="aug" value="AUG" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="610" y="180" width="60" height="35" as="geometry" />
        </mxCell>
        <mxCell id="sep" value="SEP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="690" y="180" width="60" height="35" as="geometry" />
        </mxCell>
        <mxCell id="oct" value="OCT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="770" y="180" width="60" height="35" as="geometry" />
        </mxCell>
        <mxCell id="nov" value="NOV" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="850" y="180" width="60" height="35" as="geometry" />
        </mxCell>
        <mxCell id="dec" value="DEC" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="930" y="180" width="60" height="35" as="geometry" />
        </mxCell>

        <!-- Validate -->
        <mxCell id="validate" value="T_FEED_VALIDATE&#xa;(dedup, orphan cleanup)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="470" y="280" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- Finalizer -->
        <mxCell id="finalizer" value="T_FEED_INGEST_FINALIZER&#xa;(year loop logic)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="470" y="390" width="200" height="50" as="geometry" />
        </mxCell>

        <!-- Decision box -->
        <mxCell id="decision" value="pct_done &gt;= 90%?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="510" y="490" width="140" height="70" as="geometry" />
        </mxCell>

        <!-- Advance -->
        <mxCell id="advance" value="ADVANCE&#xa;to next year&#xa;(re-trigger ROOT)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="330" y="510" width="130" height="50" as="geometry" />
        </mxCell>

        <!-- Chain -->
        <mxCell id="chain" value="CHAIN&#xa;to T_ENRICH_ROOT&#xa;(final year done)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edda;strokeColor=#28a745;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="700" y="510" width="130" height="50" as="geometry" />
        </mxCell>

        <!-- Retry -->
        <mxCell id="retry" value="RETRY&#xa;(re-trigger ROOT)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="510" y="610" width="130" height="40" as="geometry" />
        </mxCell>

        <!-- Edges from root to months -->
        <mxCell id="er1" style="endArrow=classic;html=1;strokeColor=#666;" edge="1" parent="1" source="root" target="jan"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="er2" style="endArrow=classic;html=1;strokeColor=#666;" edge="1" parent="1" source="root" target="apr"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="er3" style="endArrow=classic;html=1;strokeColor=#666;" edge="1" parent="1" source="root" target="jul"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="er4" style="endArrow=classic;html=1;strokeColor=#666;" edge="1" parent="1" source="root" target="oct"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Months to validate -->
        <mxCell id="ev1" style="endArrow=classic;html=1;strokeColor=#666;" edge="1" parent="1" source="jan" target="validate"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ev2" style="endArrow=classic;html=1;strokeColor=#666;" edge="1" parent="1" source="jul" target="validate"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ev3" style="endArrow=classic;html=1;strokeColor=#666;" edge="1" parent="1" source="dec" target="validate"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Validate to finalizer -->
        <mxCell id="evf" style="endArrow=classic;html=1;strokeColor=#666;strokeWidth=2;" edge="1" parent="1" source="validate" target="finalizer"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Finalizer to decision -->
        <mxCell id="efd" style="endArrow=classic;html=1;strokeColor=#666;" edge="1" parent="1" source="finalizer" target="decision"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Decision branches -->
        <mxCell id="eda" style="endArrow=classic;html=1;strokeColor=#82b366;strokeWidth=2;" edge="1" parent="1" source="decision" target="advance"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="edc" style="endArrow=classic;html=1;strokeColor=#28a745;strokeWidth=2;" edge="1" parent="1" source="decision" target="chain"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="edr" style="endArrow=classic;html=1;strokeColor=#b85450;dashed=1;" edge="1" parent="1" source="decision" target="retry"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Labels -->
        <mxCell id="lbl1" value="Yes + more years" style="text;html=1;strokeColor=none;fillColor=none;fontSize=8;fontColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="340" y="490" width="100" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lbl2" value="Yes + final year" style="text;html=1;strokeColor=none;fillColor=none;fontSize=8;fontColor=#28a745;" vertex="1" parent="1">
          <mxGeometry x="680" y="490" width="100" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lbl3" value="No (&lt; 90%)" style="text;html=1;strokeColor=none;fillColor=none;fontSize=8;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="550" y="580" width="80" height="20" as="geometry" />
        </mxCell>

        <!-- Parallel annotation -->
        <mxCell id="note1" value="All 12 months run&#xa;in PARALLEL" style="text;html=1;strokeColor=#cccccc;fillColor=#fffde7;align=center;fontSize=8;fontStyle=2;fontColor=#666;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="1010" y="180" width="110" height="35" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

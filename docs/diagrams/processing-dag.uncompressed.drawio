<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram id="processing-dag" name="Processing DAG">
    <mxGraphModel dx="1500" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Processing DAG — 14 Tasks" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=14;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="500" y="20" width="400" height="30" as="geometry" />
        </mxCell>

        <!-- ROOT -->
        <mxCell id="root" value="T_PROCESSING_ROOT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="70" width="160" height="40" as="geometry" />
        </mxCell>

        <!-- Chunk tasks -->
        <mxCell id="c10k" value="CHUNK_10K" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="200" y="160" width="100" height="35" as="geometry" />
        </mxCell>
        <mxCell id="c10q" value="CHUNK_10Q" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="320" y="160" width="100" height="35" as="geometry" />
        </mxCell>
        <mxCell id="c8k" value="CHUNK_8K" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="440" y="160" width="100" height="35" as="geometry" />
        </mxCell>

        <!-- Signal tasks -->
        <mxCell id="s10k" value="SIGNAL_10K" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="680" y="160" width="100" height="35" as="geometry" />
        </mxCell>
        <mxCell id="s10q" value="SIGNAL_10Q" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="800" y="160" width="100" height="35" as="geometry" />
        </mxCell>
        <mxCell id="s8k" value="SIGNAL_8K" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="920" y="160" width="100" height="35" as="geometry" />
        </mxCell>

        <!-- Middle tier -->
        <mxCell id="norm" value="NORMALIZE&#xa;SIGNALS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="580" y="260" width="100" height="40" as="geometry" />
        </mxCell>
        <mxCell id="metrics" value="METRICS&#xa;EXTRACT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="710" y="260" width="100" height="40" as="geometry" />
        </mxCell>
        <mxCell id="guidance" value="GUIDANCE&#xa;EXTRACT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="840" y="260" width="100" height="40" as="geometry" />
        </mxCell>

        <!-- Propagate -->
        <mxCell id="propagate" value="PROPAGATE_INDUSTRY&#xa;(industry + ticker to all tables)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="560" y="360" width="250" height="40" as="geometry" />
        </mxCell>

        <!-- Search refresh -->
        <mxCell id="refresh" value="REFRESH_SEARCH&#xa;(incremental)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#cce5ff;strokeColor=#004085;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="600" y="450" width="160" height="40" as="geometry" />
        </mxCell>

        <!-- Wait active -->
        <mxCell id="wait" value="WAIT_SEARCH&#xa;ACTIVE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#cce5ff;strokeColor=#004085;fontSize=8;" vertex="1" parent="1">
          <mxGeometry x="620" y="530" width="120" height="35" as="geometry" />
        </mxCell>

        <!-- Finalizer -->
        <mxCell id="finalizer" value="T_PROCESSING_FINALIZER&#xa;(email summary)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="580" y="610" width="200" height="40" as="geometry" />
        </mxCell>

        <!-- Parallel annotations -->
        <mxCell id="note1" value="PARALLEL" style="text;html=1;strokeColor=none;fillColor=none;fontSize=8;fontStyle=2;fontColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="540" y="145" width="60" height="20" as="geometry" />
        </mxCell>
        <mxCell id="note2" value="PARALLEL" style="text;html=1;strokeColor=none;fillColor=none;fontSize=8;fontStyle=2;fontColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="950" y="265" width="60" height="20" as="geometry" />
        </mxCell>

        <!-- Edges from root -->
        <mxCell id="er1" style="endArrow=classic;html=1;strokeColor=#666;" edge="1" parent="1" source="root" target="c10k"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="er2" style="endArrow=classic;html=1;strokeColor=#666;" edge="1" parent="1" source="root" target="c10q"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="er3" style="endArrow=classic;html=1;strokeColor=#666;" edge="1" parent="1" source="root" target="c8k"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="er4" style="endArrow=classic;html=1;strokeColor=#666;" edge="1" parent="1" source="root" target="s10k"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="er5" style="endArrow=classic;html=1;strokeColor=#666;" edge="1" parent="1" source="root" target="s10q"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="er6" style="endArrow=classic;html=1;strokeColor=#666;" edge="1" parent="1" source="root" target="s8k"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Signals to middle tier -->
        <mxCell id="esn" style="endArrow=classic;html=1;strokeColor=#666;" edge="1" parent="1" source="s10k" target="norm"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="esm" style="endArrow=classic;html=1;strokeColor=#666;" edge="1" parent="1" source="s10q" target="metrics"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="esg" style="endArrow=classic;html=1;strokeColor=#666;" edge="1" parent="1" source="s8k" target="guidance"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Middle to propagate -->
        <mxCell id="enp" style="endArrow=classic;html=1;strokeColor=#666;" edge="1" parent="1" source="norm" target="propagate"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="emp" style="endArrow=classic;html=1;strokeColor=#666;" edge="1" parent="1" source="metrics" target="propagate"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ecp" style="endArrow=classic;html=1;strokeColor=#666;" edge="1" parent="1" source="c10k" target="propagate"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Propagate to refresh -->
        <mxCell id="epr" style="endArrow=classic;html=1;strokeColor=#004085;strokeWidth=2;" edge="1" parent="1" source="propagate" target="refresh"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Refresh to wait -->
        <mxCell id="erw" style="endArrow=classic;html=1;strokeColor=#004085;" edge="1" parent="1" source="refresh" target="wait"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Wait to finalizer (implicit via FINALIZE) -->
        <mxCell id="ewf" style="endArrow=classic;html=1;strokeColor=#b85450;dashed=1;" edge="1" parent="1" source="wait" target="finalizer"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram id="data-model" name="Data Model">
    <mxGraphModel dx="1400" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Data Model — Table Relationships" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=14;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="450" y="20" width="400" height="30" as="geometry" />
        </mxCell>

        <!-- FILING_INDEX -->
        <mxCell id="fi" value="FILING_INDEX&#xa;─────────────────&#xa;ACCESSION_NO (PK)&#xa;CIK&#xa;COMPANY_NAME&#xa;FORM_TYPE&#xa;FILED_AT&#xa;PERIOD_OF_REPORT&#xa;TICKER&#xa;INDUSTRY_SECTOR&#xa;SIC_CODE&#xa;DOWNLOADED_AT&#xa;TICKER_CHECKED_AT" style="shape=table;startSize=0;container=0;collapsible=0;childLayout=tableLayout;fontSize=8;align=left;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="100" y="100" width="180" height="210" as="geometry" />
        </mxCell>

        <!-- FILING_CONTENT -->
        <mxCell id="fc" value="FILING_CONTENT&#xa;─────────────────&#xa;ACCESSION_NO (FK)&#xa;CONTENT_TEXT&#xa;FILE_SIZE_BYTES&#xa;FILE_FORMAT&#xa;PARSE_STATUS&#xa;SIGNAL_STATUS&#xa;PROCESSED_AT" style="shape=table;startSize=0;container=0;collapsible=0;childLayout=tableLayout;fontSize=8;align=left;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="100" y="380" width="180" height="160" as="geometry" />
        </mxCell>

        <!-- FILING_CHUNKS -->
        <mxCell id="chunks" value="FILING_CHUNKS&#xa;─────────────────&#xa;CHUNK_ID (PK)&#xa;ACCESSION_NO (FK)&#xa;SECTION_NAME&#xa;CHUNK_INDEX&#xa;CHUNK_TEXT&#xa;TOKEN_COUNT&#xa;COMPANY_NAME&#xa;TICKER&#xa;FORM_TYPE&#xa;INDUSTRY_SECTOR" style="shape=table;startSize=0;container=0;collapsible=0;childLayout=tableLayout;fontSize=8;align=left;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="500" y="80" width="180" height="200" as="geometry" />
        </mxCell>

        <!-- FILING_SIGNALS -->
        <mxCell id="signals" value="FILING_SIGNALS&#xa;─────────────────&#xa;SIGNAL_ID (PK)&#xa;ACCESSION_NO (FK)&#xa;EVENT_TYPE&#xa;EVENT_TYPE_NORMALIZED&#xa;SENTIMENT&#xa;SUMMARY&#xa;REVENUE / REVENUE_NORMALIZED&#xa;NET_INCOME&#xa;EPS / EPS_NORMALIZED&#xa;FORWARD_GUIDANCE&#xa;INDUSTRY_SECTOR&#xa;EXTRACTION_MODEL&#xa;METRICS_EXTRACTED_AT&#xa;GUIDANCE_EXTRACTED_AT" style="shape=table;startSize=0;container=0;collapsible=0;childLayout=tableLayout;fontSize=8;align=left;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="500" y="340" width="200" height="260" as="geometry" />
        </mxCell>

        <!-- Cortex Search -->
        <mxCell id="search" value="CORTEX SEARCH&#xa;SERVICE&#xa;(indexes FILING_CHUNKS)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#cce5ff;strokeColor=#004085;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="850" y="130" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- Semantic View -->
        <mxCell id="semview" value="SEMANTIC VIEW&#xa;(queries FILING_SIGNALS live)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6d0de;strokeColor=#996699;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="850" y="420" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- _FEED_INGEST_LOG -->
        <mxCell id="log" value="_FEED_INGEST_LOG&#xa;─────────────────&#xa;FEED_DATE&#xa;STATUS&#xa;LOADED" style="shape=table;startSize=0;container=0;collapsible=0;childLayout=tableLayout;fontSize=8;align=left;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="1100" y="100" width="140" height="100" as="geometry" />
        </mxCell>

        <!-- _PIPELINE_CONFIG -->
        <mxCell id="config" value="_PIPELINE_CONFIG&#xa;─────────────────&#xa;KEY&#xa;VALUE" style="shape=table;startSize=0;container=0;collapsible=0;childLayout=tableLayout;fontSize=8;align=left;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="1100" y="240" width="140" height="80" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <mxCell id="e1" value="1:1" style="endArrow=classic;html=1;strokeColor=#6c8ebf;strokeWidth=2;" edge="1" parent="1" source="fi" target="fc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="1:N" style="endArrow=classic;html=1;strokeColor=#d6b656;strokeWidth=2;" edge="1" parent="1" source="fc" target="chunks">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="1:1" style="endArrow=classic;html=1;strokeColor=#d6b656;strokeWidth=2;" edge="1" parent="1" source="fc" target="signals">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" style="endArrow=classic;html=1;strokeColor=#004085;dashed=1;strokeWidth=2;" edge="1" parent="1" source="chunks" target="search">
          <mxGeometry relative="1" as="geometry" />
